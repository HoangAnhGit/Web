@model QuanLyChoThuePhongTro.Models.Room

@{
    ViewData["Title"] = "Chi tiết phòng";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Xử lý danh sách ảnh
    var imageList = !string.IsNullOrEmpty(Model.ImageUrls)
        ? Model.ImageUrls.Split(',', StringSplitOptions.RemoveEmptyEntries).ToList()
        : new List<string>();
}

<div class="container page-section">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card info-card">
                <div class="card-body p-4">
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
                        <div>
                            <h2 class="mb-1">@Model.Title</h2>
                            <p class="text-muted mb-0">Chi tiết đầy đủ phòng trọ và tiện ích đi kèm</p>
                        </div>
                        <span class="badge fs-6 @(Model.Status == "Available" ? "bg-success" : Model.Status == "Rented" ? "bg-warning text-dark" : "bg-danger")">
                            @(Model.Status == "Available" ? "Có sẵn" : Model.Status == "Rented" ? "Đã cho thuê" : "Bảo trì")
                        </span>
                    </div>

                    @if (imageList.Count > 0)
                    {
                        <div class="mb-4">
                            <h5 class="mb-3">Ảnh phòng</h5>
                            <div class="mb-2">
                                <img id="mainImage" src="@imageList[0]" alt="Ảnh phòng"
                                     class="img-fluid rounded shadow-sm"
                                     style="width:100%;max-height:420px;object-fit:cover;cursor:pointer;" />
                            </div>
                            @if (imageList.Count > 1)
                            {
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var imgUrl in imageList)
                                    {
                                        <img src="@imgUrl" alt="Ảnh phòng"
                                             class="rounded border thumbnail-img"
                                             style="width:100px;height:75px;object-fit:cover;cursor:pointer;opacity:0.8;transition:opacity 0.2s;"
                                             onclick="document.getElementById('mainImage').src=this.src"
                                             onmouseover="this.style.opacity='1'"
                                             onmouseout="this.style.opacity='0.8'" />
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="mb-4 p-4 bg-light rounded text-center text-muted">
                            <p class="mb-0">📷 Chưa có ảnh phòng</p>
                        </div>
                    }

                    <h5 class="mb-3">Thông tin cơ bản</h5>
                    <div class="table-responsive">
                        <table class="table table-borderless align-middle mb-4">
                            <tr>
                                <th class="w-25 text-muted">Giá thuê</th>
                                <td class="fw-semibold text-danger">@Model.Price.ToString("N0") VNĐ/tháng</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Vị trí</th>
                                <td>@Model.Location, @Model.District, @Model.Ward</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Diện tích</th>
                                <td>@Model.Area m²</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Phòng ngủ</th>
                                <td>@Model.Bedrooms</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Phòng tắm</th>
                                <td>@Model.Bathrooms</td>
                            </tr>
                        </table>
                    </div>

                    <h5 class="mb-2">Tiện ích</h5>
                    <div class="d-flex flex-wrap gap-2 mb-4">
                        @if (Model.HasKitchen)
                        {
                            <span class="badge bg-secondary">Có bếp</span>
                        }
                        @if (Model.HasWiFi)
                        {
                            <span class="badge bg-secondary">Có WiFi</span>
                        }
                        @if (Model.HasAirConditioner)
                        {
                            <span class="badge bg-secondary">Có điều hòa</span>
                        }
                        @if (Model.HasWashing)
                        {
                            <span class="badge bg-secondary">Có máy giặt</span>
                        }
                        @if (!Model.HasKitchen && !Model.HasWiFi && !Model.HasAirConditioner && !Model.HasWashing)
                        {
                            <span class="text-muted">Chưa cập nhật tiện ích.</span>
                        }
                    </div>

                    <h5 class="mb-2">Mô tả</h5>
                    <p class="mb-0">@Model.Description</p>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2 mt-3">
                @if (Model.Status == "Available" && ViewBag.UserRole == "Tenant")
                {
                    <a href="@Url.Action("Create", "RentalContract", new { roomId = Model.Id })" class="btn btn-primary">
                        <i class="fas fa-file-signature me-1"></i> Đăng ký thuê
                    </a>
                }

                @if (ViewBag.UserId == Model.OwnerId && ViewBag.UserRole == "Landlord")
                {
                    <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-warning">Sửa</a>
                    <a href="@Url.Action("Delete", new { id = Model.Id })" class="btn btn-outline-danger">Xóa</a>
                }

                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Quay lại</a>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card info-card">
                <div class="card-body p-4">
                    <h5 class="card-title mb-3">Thông tin chủ nhà</h5>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2"><strong>Tên:</strong> @Model.Owner?.FullName</li>
                        <li class="mb-2"><strong>Email:</strong> @Model.Owner?.Email</li>
                        <li><strong>Điện thoại:</strong> @Model.Owner?.PhoneNumber</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
