@model QuanLyChoThuePhongTro.Models.RentalContract

@{
    ViewData["Title"] = "Sửa hợp đồng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container page-section">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <div>
            <h2 class="mb-1">Sửa Hợp Đồng Thuê Phòng</h2>
            <p class="text-muted mb-0">Cập nhật thông tin hợp đồng và điều khoản thuê.</p>
        </div>

    <div id="editContractAlert"></div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card info-card">
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="RoomId" />
                        <input type="hidden" asp-for="TenantId" />
                        <input type="hidden" asp-for="LandlordId" />
                        <input type="hidden" asp-for="CreatedDate" />

            <div class="mb-3">
                <label class="form-label">Phòng</label>
                <input value="@Model.Room?.Title" class="form-control" readonly />
            </div>

            <div class="mb-3">
                <label class="form-label">Người thuê</label>
                <input value="@Model.Tenant?.FullName" class="form-control" readonly />
            </div>

            <div class="mb-3">
                <label asp-for="MonthlyPrice" class="form-label">Giá hàng tháng (VNĐ)</label>
                <input asp-for="MonthlyPrice" class="form-control" type="number" min="0" readonly />
                <span asp-validation-for="MonthlyPrice" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Deposit" class="form-label">Tiền cọc (VNĐ)</label>
                <input asp-for="Deposit" class="form-control" type="number" min="0" />
                <span asp-validation-for="Deposit" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="StartDate" class="form-label">Ngày bắt đầu</label>
                <input asp-for="StartDate" class="form-control" type="date" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="EndDate" class="form-label">Ngày kết thúc</label>
                <input asp-for="EndDate" class="form-control" type="date" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Status" class="form-label">Trạng thái</label>
                <select asp-for="Status" class="form-select">
                    <option value="Pending">Chờ xác nhận</option>
                    <option value="Active">Đang hoạt động</option>
                    <option value="Expired">Hết hạn</option>
                    <option value="Terminated">Đã kết thúc</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="TermsAndConditions" class="form-label">Điều khoản và điều kiện</label>
                <textarea asp-for="TermsAndConditions" class="form-control" rows="4"></textarea>
            </div>

                        <div class="d-flex gap-2 flex-wrap">
                            <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        $(function () {
            function showAlert(type, message) {
                $('#editContractAlert').html(
                    `<div class="alert alert-${type} alert-dismissible fade show" role="alert">${message}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>`
                );
            }

            $('form[asp-action="Edit"], form').on('submit', function (e) {
                const startDate = $('#StartDate').val();
                const endDate = $('#EndDate').val();

                if (startDate && endDate && startDate >= endDate) {
                    e.preventDefault();
                    showAlert('danger', 'Ngày bắt đầu phải nhỏ hơn ngày kết thúc.');
                    return false;
                }

                return true;
            });
        });
    </script>
}
