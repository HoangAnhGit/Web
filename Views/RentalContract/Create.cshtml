@model QuanLyChoThuePhongTro.Models.RentalContract

@{
    ViewData["Title"] = "Tạo hợp đồng mới";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container page-section">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <div>
            <h2 class="mb-1">Đăng Ký Thuê Phòng</h2>
            <p class="text-muted mb-0">Hoàn tất thông tin bên dưới để gửi yêu cầu tạo hợp đồng.</p>
        </div>
        <a href="@Url.Action("Index", "Room")" class="btn btn-outline-secondary">Quay lại danh sách phòng</a>
    </div>

    <div id="ajaxAlertContainer"></div>

    <div class="card info-card">
        <div class="card-body p-4">
            <form asp-action="Create" method="post" id="createContractForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="roomId" id="roomId" value="@Model.RoomId" />
                <input type="hidden" name="tenantId" value="@Model.TenantId" />
                <input type="hidden" name="landlordId" value="@Model.LandlordId" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="monthlyPrice" class="form-label">Giá hàng tháng (VNĐ)</label>
                        <input type="number" class="form-control" id="monthlyPrice" name="monthlyPrice" value="@Model.MonthlyPrice" readonly />
                    </div>

                    <div class="col-md-6">
                        <label for="deposit" class="form-label">Tiền cọc (VNĐ)</label>
                        <input type="number" class="form-control" id="deposit" name="deposit" value="@Model.Deposit" min="0" />
                    </div>

                    <div class="col-md-6">
                        <label for="startDate" class="form-label">Ngày bắt đầu</label>
                        <input type="date" class="form-control" id="startDate" name="startDate" required />
                    </div>

                    <div class="col-md-6">
                        <label for="endDate" class="form-label">Ngày kết thúc</label>
                        <input type="date" class="form-control" id="endDate" name="endDate" required />
                    </div>

                    <div class="col-12">
                        <label for="termsAndConditions" class="form-label">Điều khoản và điều kiện</label>
                        <textarea class="form-control" id="termsAndConditions" name="termsAndConditions" rows="6" placeholder="Ví dụ: Thanh toán trước ngày 05 hàng tháng..."></textarea>
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2 mt-4">
                    <button type="submit" id="createContractBtn" class="btn btn-primary">
                        <i class="fas fa-file-signature me-1"></i> Tạo hợp đồng
                    </button>
                    <a href="@Url.Action("Index", "Room")" class="btn btn-outline-secondary">Hủy</a>
                </div>
            </form>
        </div>
    </div>

    <div id="ajaxResult" class="mt-3"></div>
</div>

@section Scripts {
    <script>
        $(function () {
            const form = $('#createContractForm');
            const btn = $('#createContractBtn');

            function showAlert(type, message) {
                $('#ajaxAlertContainer').html(
                    `<div class="alert alert-${type} alert-dismissible fade show" role="alert">${message}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>`
                );
            }

            form.on('submit', async function (e) {
                e.preventDefault();

                const startDate = $('#startDate').val();
                const endDate = $('#endDate').val();

                if (startDate && endDate && startDate >= endDate) {
                    showAlert('danger', 'Ngày bắt đầu phải nhỏ hơn ngày kết thúc.');
                    return;
                }

                const payload = {
                    roomId: parseInt($('#roomId').val(), 10),
                    deposit: parseFloat($('#deposit').val() || '0'),
                    startDate: startDate,
                    endDate: endDate,
                    termsAndConditions: $('#termsAndConditions').val()
                };

                btn.prop('disabled', true);

                try {
                    const token = $('input[name="__RequestVerificationToken"]').val();
                    const response = await fetch('@Url.Action("CreateAjax", "RentalContract")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        },
                        body: JSON.stringify(payload)
                    });

                    const result = await response.json();

                    if (!response.ok || !result.success) {
                        showAlert('danger', result.message || 'Tạo hợp đồng thất bại.');
                        return;
                    }

                    showAlert('success', result.message || 'Tạo hợp đồng thành công.');

                    $('#ajaxResult').html(`
                        <div class="card border-success shadow-sm">
                            <div class="card-body">
                                <h6 class="text-success mb-2">Yêu cầu đã được gửi</h6>
                                <p class="mb-2">Mã hợp đồng: <strong>#${result.data.contractId}</strong></p>
                                <p class="mb-3">Trạng thái: <span class="badge bg-warning text-dark">${result.data.status}</span></p>
                                <a href="${result.data.contractDetailsUrl}" class="btn btn-sm btn-outline-primary">Xem chi tiết hợp đồng</a>
                            </div>
                        </div>
                    `);

                    form.trigger('reset');
                } catch {
                    showAlert('danger', 'Có lỗi hệ thống khi gửi yêu cầu. Vui lòng thử lại.');
                } finally {
                    btn.prop('disabled', false);
                }
            });
        });
    </script>
}
