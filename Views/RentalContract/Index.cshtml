@model IEnumerable<QuanLyChoThuePhongTro.Models.RentalContract>

@{
    ViewData["Title"] = "Danh sách hợp đồng";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var role = ViewBag.UserRole as string;
    var userId = (int)(ViewBag.UserId ?? 0);
}

<div class="container page-section">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <div>
            <h2 class="mb-1">Danh Sách Hợp Đồng Thuê Phòng</h2>
            <p class="text-muted mb-0">Theo dõi trạng thái hợp đồng và thao tác nhanh ngay tại đây.</p>
        </div>
    </div>

    <div id="contractActionAlert"></div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card info-card">
        <div class="card-body p-3 p-md-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Phòng</th>
                            <th>Người thuê</th>
                            <th>Chủ nhà</th>
                            <th>Giá hàng tháng</th>
                            <th>Từ ngày</th>
                            <th>Đến ngày</th>
                            <th>Trạng thái</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var contract in Model)
                        {
                            <tr id="contract-row-@contract.Id">
                                <td>@contract.Id</td>
                                <td>@contract.Room?.Title</td>
                                <td>@contract.Tenant?.FullName</td>
                                <td>@contract.Landlord?.FullName</td>
                                <td>@contract.MonthlyPrice.ToString("N0") VNĐ</td>
                                <td>@contract.StartDate.ToString("dd/MM/yyyy")</td>
                                <td>@contract.EndDate.ToString("dd/MM/yyyy")</td>
                                <td class="contract-status-cell">
                                    @if (contract.Status == "Active")
                                    {
                                        <span class="badge bg-success">Đang hoạt động</span>
                                    }
                                    else if (contract.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark">Chờ xác nhận</span>
                                    }
                                    else if (contract.Status == "Expired")
                                    {
                                        <span class="badge bg-danger">Hết hạn</span>
                                    }
                                    else if (contract.Status == "Terminated")
                                    {
                                        <span class="badge bg-secondary">Đã kết thúc</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@contract.Status</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1 flex-wrap">
                                        <a href="@Url.Action("Details", new { id = contract.Id })" class="btn btn-sm btn-info">Xem</a>

                                        @if (contract.Status == "Active" && role == "Tenant")
                                        {
                                            <form method="post" action="@Url.Action("QuickPayAjax", "Payment", new { contractId = contract.Id })" style="display:inline" class="js-contract-ajax-form" data-kind="quickpay">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-success"
                                                        onclick="return confirm('Bạn có muốn thanh toán ngay số tiền @contract.MonthlyPrice.ToString("N0") VNĐ?')">
                                                    💵 Thanh toán
                                                </button>
                                            </form>
                                        }
                                        else if (contract.Status == "Active")
                                        {
                                            <a href="@Url.Action("ByContract", "Payment", new { contractId = contract.Id })" class="btn btn-sm btn-dark">📋 Lịch sử</a>
                                        }

                                        @if (role == "Landlord" && contract.LandlordId == userId)
                                        {
                                            <a href="@Url.Action("Edit", new { id = contract.Id })" class="btn btn-sm btn-warning">Sửa</a>
                                        }

                                        @if (role == "Landlord" && contract.LandlordId == userId && contract.Status == "Pending")
                                        {
                                            <div class="pending-contract-actions d-flex gap-1 flex-wrap">
                                                <form method="post" action="@Url.Action("ApproveAjax", new { id = contract.Id })" style="display:inline" class="js-contract-ajax-form" data-kind="approve" data-contract-id="@contract.Id">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-success"
                                                            onclick="return confirm('Xác nhận chấp thuận hợp đồng này?')">
                                                        ✔ Xác nhận
                                                    </button>
                                                </form>
                                                <form method="post" action="@Url.Action("RejectAjax", new { id = contract.Id })" style="display:inline" class="js-contract-ajax-form" data-kind="reject" data-contract-id="@contract.Id">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-danger"
                                                            onclick="return confirm('Bạn có chắc muốn từ chối hợp đồng này?')">
                                                        ✖ Từ chối
                                                    </button>
                                                </form>
                                            </div>
                                        }

                                        @if (role == "Landlord" && contract.LandlordId == userId)
                                        {
                                            <a href="@Url.Action("Delete", new { id = contract.Id })" class="btn btn-sm btn-outline-danger">Xóa</a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            let isSyncingContractTable = false;

            function showAlert(type, message) {
                $('#contractActionAlert').html(
                    `<div class="alert alert-${type} alert-dismissible fade show" role="alert">${message}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>`
                );
            }

            async function syncContractTableSilently() {
                if (isSyncingContractTable || document.hidden) return;
                isSyncingContractTable = true;

                try {
                    const response = await fetch(window.location.href, { cache: 'no-store' });
                    if (!response.ok) return;

                    const html = await response.text();
                    const dom = $($.parseHTML(html));
                    const newTbody = dom.find('table tbody').html();
                    if (newTbody) {
                        $('table tbody').html(newTbody);
                    }
                } catch {
                    // Silent background sync
                } finally {
                    isSyncingContractTable = false;
                }
            }

            function updateContractRow(contractId, statusClass, statusText) {
                const row = $(`#contract-row-${contractId}`);
                if (!row.length) return;

                row.find('.contract-status-cell').html(`<span class="badge ${statusClass}">${statusText}</span>`);
                row.find('.pending-contract-actions').remove();
            }

            $(document).on('submit', '.js-contract-ajax-form', function (e) {
                e.preventDefault();

                const form = $(this);
                const button = form.find('button[type="submit"]');
                const contractId = form.data('contract-id');
                const kind = form.data('kind');

                button.prop('disabled', true);

                $.ajax({
                    url: form.attr('action'),
                    type: 'POST',
                    data: form.serialize(),
                    success: function (res) {
                        if (!res || !res.success) {
                            showAlert('danger', res?.message || 'Thao tác thất bại.');
                            return;
                        }

                        showAlert('success', res.message || 'Thao tác thành công.');

                        if (kind === 'approve' || kind === 'reject') {
                            updateContractRow(contractId, res.data.statusClass, res.data.statusText);
                        }
                    },
                    error: function (xhr) {
                        showAlert('danger', xhr?.responseJSON?.message || 'Có lỗi xảy ra khi xử lý yêu cầu.');
                    },
                    complete: function () {
                        button.prop('disabled', false);
                    }
                });
            });

            setInterval(syncContractTableSilently, 5000);
        });
    </script>
}
